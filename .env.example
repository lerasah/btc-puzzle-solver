# Copy this to ".env" (which is gitignored) and fill in, OR just `export` these vars.
# NEVER commit the real webhook URL to git.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY
# Optional: override worker count (defaults to all CPU cores)
# WORKERS=32
# Optional: where checkpoints / SOLVED files are written (default /workspace)
# WORKDIR=/workspace
