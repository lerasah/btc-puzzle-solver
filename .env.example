# Copy this to ".env" (gitignored) or just `export` these vars.
# NEVER commit the real webhook URLs to git.

# Status pings: batch start, per-job start, heartbeats, "exhausted"/"complete".
DISCORD_STATUS_WEBHOOK_URL=https://discord.com/api/webhooks/AAAA/BBBB

# Result ONLY: the 🎉 "found" alert.
DISCORD_RESULT_WEBHOOK_URL=https://discord.com/api/webhooks/CCCC/DDDD

# Optional single fallback used for both if the two above are unset:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# Optional: override worker count (defaults to all CPU cores)
# WORKERS=32
# Optional: where checkpoints / SOLVED files are written (default /workspace)
# WORKDIR=/workspace
